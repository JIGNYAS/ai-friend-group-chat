# Telegram Bot Tokens (one per friend - get from @BotFather)
TELEGRAM_BOT_TOKEN_MAYA=your_maya_bot_token
TELEGRAM_BOT_TOKEN_DEV=your_dev_bot_token
TELEGRAM_BOT_TOKEN_ZEN=your_zen_bot_token

# Telegram Group Chat ID (get this after creating group and running get_chat_id.py)
TELEGRAM_GROUP_CHAT_ID=your_group_chat_id

# AI Provider - choose "groq" or "openai"
AI_PROVIDER=groq

# Groq API Key (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key

# OR OpenAI API Key
# OPENAI_API_KEY=your_openai_api_key
